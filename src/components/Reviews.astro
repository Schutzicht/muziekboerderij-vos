---
const reviews = [
  {
    name: "Lars van der Berg",
    band: "The Clockwork Owls",
    text: "We huren al 3 jaar een loods bij Muziekboerderij Vos. De sfeer is uniek, de apparatuur top en de mensen geweldig.",
    avatar: "L",
    type: "Band"
  },
  {
    name: "Sanne Meijers",
    band: "Sanne M. — Solo",
    text: "De vodatent was perfect voor ons schrijfweekend. Midden in de natuur, maar met alle comfort. 's Avonds langs de loodsen slenteren. Magic.",
    avatar: "S",
    type: "Camping"
  },
  {
    name: "Rick & Fatima",
    band: "Duo Amber Road",
    text: "Wij kwamen voor de lessen en bleven voor de camping. Joost en zijn team maken je echt welkom.",
    avatar: "R",
    type: "Band"
  },
  {
    name: "Merel de Vries",
    band: "Bezoeker",
    text: "Gewoon een weekend kamperen met muziek om je heen. Zo bijzonder. Je hoeft zelf geen muzikant te zijn om dit te waarderen.",
    avatar: "M",
    type: "Camping"
  }
];
---

<section id="ervaringen" class="py-20 md:py-28 bg-primary-green">
  <div class="container mx-auto px-6 max-w-5xl">

    <div class="mb-12 animate-on-scroll">
      <p class="text-accent-tan uppercase tracking-widest text-xs font-bold mb-3 font-montserrat">Ervaringen</p>
      <h2 class="text-3xl md:text-5xl text-white">Wat mensen zeggen.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {reviews.map((review, idx) => (
        <div class={`border border-white/10 rounded-2xl p-8 animate-on-scroll delay-${idx * 100}`}>
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-accent-tan/20 border border-accent-tan/30 flex items-center justify-center text-accent-tan text-sm font-bold font-fredoka shrink-0">
                {review.avatar}
              </div>
              <div>
                <p class="text-white text-sm font-fredoka uppercase tracking-wide">{review.name}</p>
                <p class="text-white/35 text-xs font-montserrat">{review.band}</p>
              </div>
            </div>
            <span class="text-[10px] uppercase tracking-widest font-montserrat font-bold px-3 py-1 rounded-full border border-white/10 text-white/30">
              {review.type}
            </span>
          </div>
          <p class="text-white/60 text-sm font-montserrat font-light leading-relaxed">
            "{review.text}"
          </p>
          <div class="flex gap-0.5 mt-4">
            {Array.from({ length: 5 }).map(() => <span class="text-accent-tan text-xs">★</span>)}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
