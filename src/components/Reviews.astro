---
const reviews = [
  {
    name: "Lars van der Berg",
    band: "The Clockwork Owls",
    text: "We huren al 3 jaar een loods bij Muziekboerderij Vos. De sfeer is uniek, de apparatuur top en de mensen geweldig. Niet meer weg te denken.",
    avatar: "L"
  },
  {
    name: "Sanne Meijers",
    band: "Sanne M. — Solo",
    text: "De vodatent was perfect voor ons schrijfweekend. Midden in de natuur, maar met alle comfort. 's Avonds langs de loodsen slenteren met een biertje. Magic.",
    avatar: "S"
  },
  {
    name: "Rick & Fatima",
    band: "Duo Amber Road",
    text: "Wij kwamen voor de lessen en bleven voor de camping. Joost en zijn team maken je echt welkom. Aan te raden voor iedereen die muziek serieus neemt.",
    avatar: "R"
  }
];
---

<section id="ervaringen" class="py-24 md:py-36 bg-primary-green overflow-hidden">
  <div class="container mx-auto px-6">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-6 animate-on-scroll">
      <h2 class="text-5xl md:text-8xl text-white leading-none">Wat<br/><span class="text-accent-tan">bands</span><br/>zeggen.</h2>
      <p class="text-white/40 text-sm font-montserrat font-light max-w-xs md:text-right leading-relaxed">
        Meer dan 30 vaste bands en honderden muzikanten gingen je voor.
      </p>
    </div>

    <!-- Reviews layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

      <!-- Featured review (large) -->
      <div class="lg:col-span-7 border border-white/10 rounded-3xl p-10 md:p-14 relative animate-on-scroll">
        <span class="absolute top-8 right-10 text-[8rem] leading-none text-white/5 font-fredoka select-none">"</span>
        <p class="text-white text-2xl md:text-3xl font-light font-montserrat leading-relaxed mb-12 relative z-10">
          "{reviews[1].text}"
        </p>
        <div class="flex items-center gap-4">
          <div class="w-11 h-11 rounded-full bg-accent-tan/20 border border-accent-tan/30 flex items-center justify-center text-accent-tan font-bold font-fredoka">
            {reviews[1].avatar}
          </div>
          <div>
            <p class="text-white text-sm font-fredoka uppercase tracking-wider">{reviews[1].name}</p>
            <p class="text-white/35 text-xs font-montserrat">{reviews[1].band}</p>
          </div>
          <div class="ml-auto flex gap-0.5">
            {Array.from({ length: 5 }).map(() => <span class="text-accent-tan text-base">★</span>)}
          </div>
        </div>
      </div>

      <!-- Two smaller reviews stacked -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        {[reviews[0], reviews[2]].map((review, idx) => (
          <div class={`flex-1 bg-white/5 rounded-3xl p-8 relative animate-on-scroll delay-${(idx + 1) * 100}`}>
            <p class="text-white/70 text-base font-montserrat font-light leading-relaxed mb-8">
              "{review.text}"
            </p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-accent-tan/20 border border-accent-tan/30 flex items-center justify-center text-accent-tan text-sm font-bold font-fredoka shrink-0">
                {review.avatar}
              </div>
              <div>
                <p class="text-white/80 text-xs font-fredoka uppercase tracking-wider">{review.name}</p>
                <p class="text-white/30 text-xs font-montserrat">{review.band}</p>
              </div>
              <div class="ml-auto flex gap-0.5">
                {Array.from({ length: 5 }).map(() => <span class="text-accent-tan text-sm">★</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
