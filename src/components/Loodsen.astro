---
import { Music, Mic2, Disc, Timer } from 'lucide-astro';

const features = [
  { icon: Music, title: "12 Repetitieruimtes", text: "Unieke, sfeervolle loodsen voor bands van elk formaat." },
  { icon: Mic2, title: "Zang & Lessen", text: "Drumles, breakdance en 1-op-1 coaching in een inspirerende omgeving." },
  { icon: Disc, title: "Backline Ready", text: "Kwaliteitsapparatuur aanwezig in geselecteerde ruimtes." },
  { icon: Timer, title: "Toegang tot 23:00", text: "Voor vaste bands die op onverwachte momenten hun creativiteit kwijt willen. Stilte na 23:00." },
];
---

<section id="loodsen" class="py-24 md:py-32 bg-primary-green text-white">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto text-center mb-20 animate-on-scroll">
      <h2 class="text-4xl md:text-7xl mb-6">De Loodsen</h2>
      <p class="text-white/70 text-xl md:text-2xl font-light">
        Twaalf gefaciliteerde ruimtes met elk een eigen karakter. Geschikt voor individuele lessen, workshops en bandrepetities.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
      <!-- Main Showpiece -->
      <div class="group relative rounded-3xl overflow-hidden shadow-2xl h-[400px] lg:h-full min-h-[400px] animate-on-scroll">
        <img 
          src="/muziekloods.png" 
          alt="Muziekloods Interieur" 
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary-green via-transparent to-transparent opacity-60"></div>
        <div class="absolute bottom-10 left-10 right-10">
          <h3 class="text-3xl text-accent-tan mb-2">De 'Grote Loods'</h3>
          <p class="text-white/90">Onze ruimste studio met die typische 'Barn Rats' vibe en perfecte akoestiek.</p>
        </div>
      </div>

      <!-- Feature Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {features.map((item, idx) => (
          <div class={`bg-white/5 border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all hover:border-accent-tan/50 group animate-on-scroll delay-${(idx + 1) * 100}`}>
            <div class="w-14 h-14 bg-accent-tan/20 rounded-2xl flex items-center justify-center text-accent-tan mb-6 group-hover:scale-110 transition-transform">
              <item.icon size={28} />
            </div>
            <h4 class="text-xl text-accent-tan mb-2">{item.title}</h4>
            <p class="text-white/60 leading-relaxed font-light">{item.text}</p>
          </div>
        ))}
      </div>
    </div>

    <p class="text-white/25 text-xs font-montserrat text-center mt-12 animate-on-scroll">
      Stiltetijd van 23:00 — 08:00 · Wij respecteren onze omgeving en buren.
    </p>
  </div>
</section>
