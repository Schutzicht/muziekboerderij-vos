---
---

<div class="vinyl-container relative group">
  <!-- Outer Ring / Sleeve Glow -->
  <div class="absolute inset-[-10%] bg-accent-tan/5 rounded-full blur-2xl group-hover:bg-accent-tan/10 transition-colors duration-700"></div>
  
  <!-- Vinyl Disks -->
  <div class="vinyl relative w-64 h-64 md:w-80 md:h-80 mx-auto">
    <!-- The Record -->
    <div class="record absolute inset-0 bg-zinc-900 rounded-full shadow-2xl border-4 border-zinc-800 overflow-hidden">
      <!-- Grooves -->
      <div class="absolute inset-0 bg-[radial-gradient(circle,_transparent_30%,_rgba(255,255,255,0.05)_31%,_rgba(255,255,255,0.05)_32%,_transparent_33%)] bg-[length:10px_10px]"></div>
      <div class="absolute inset-4 rounded-full border border-white/5 opacity-50"></div>
      <div class="absolute inset-8 rounded-full border border-white/5 opacity-40"></div>
      <div class="absolute inset-16 rounded-full border border-white/5 opacity-30"></div>
      
      <!-- Shine / Highlight -->
      <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/5 to-transparent rotate-45 transform skew-x-12 opacity-40"></div>
      
      <!-- Center Label -->
      <div class="absolute inset-[30%] bg-accent-tan rounded-full flex items-center justify-center border-4 border-zinc-900 shadow-inner">
        <div class="text-primary-green font-fredoka font-bold text-center text-[8px] md:text-[10px] leading-tight">
          MUZIEKBOERDERIJ<br/>
          <span class="text-lg md:text-xl">VOS</span><br/>
          <span class="text-[6px] md:text-[8px] opacity-70 italic tracking-widest uppercase">Side A</span>
        </div>
        <!-- Spindle Hole -->
        <div class="absolute inset-[45%] bg-zinc-900 rounded-full shadow-lg"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .vinyl-container {
    perspective: 1000px;
  }

  .vinyl {
    transform-style: preserve-3d;
    transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .vinyl-container:hover .vinyl {
    transform: rotateX(10deg) rotateY(-10deg) scale(1.05);
  }

  .record {
    animation: spin 8s linear infinite;
    box-shadow: 
      0 0 0 1px rgba(0,0,0,0.8),
      0 10px 40px rgba(0,0,0,0.4),
      inset 0 0 50px rgba(255,255,255,0.05);
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Responsive tweaks */
  @media (max-width: 768px) {
    .vinyl {
      width: 250px;
      height: 250px;
    }
  }
</style>

<script>
  const container = document.querySelector('.vinyl-container') as HTMLElement;
  const record = document.querySelector('.record') as HTMLElement;

  let slowTimer: ReturnType<typeof setInterval> | null = null;
  let spinTimer: ReturnType<typeof setInterval> | null = null;

  async function playDJScratch() {
    const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
    await ctx.resume();

    const now = ctx.currentTime;

    // [timeOffset, duration, filterFreqStart, filterFreqEnd, gain]
    // wik - ke   wik - ke   waaaak - ka
    const hits: [number, number, number, number, number][] = [
      [0.00, 0.08, 900,  2400, 0.4],
      [0.11, 0.08, 2400, 900,  0.4],
      [0.22, 0.08, 900,  2400, 0.4],
      [0.33, 0.08, 2400, 900,  0.4],
      [0.46, 0.20, 700,  2600, 0.5],
      [0.68, 0.18, 2600, 400,  0.45],
    ];

    hits.forEach(([offset, dur, f1, f2, g]) => {
      const t = now + offset;
      const bufLen = Math.ceil(ctx.sampleRate * (dur + 0.06));
      const buf = ctx.createBuffer(1, bufLen, ctx.sampleRate);
      const data = buf.getChannelData(0);
      for (let i = 0; i < bufLen; i++) data[i] = Math.random() * 2 - 1;

      const src = ctx.createBufferSource();
      src.buffer = buf;

      const bp = ctx.createBiquadFilter();
      bp.type = 'bandpass';
      bp.frequency.setValueAtTime(f1, t);
      bp.frequency.linearRampToValueAtTime(f2, t + dur);
      bp.Q.value = 3;

      const gainNode = ctx.createGain();
      gainNode.gain.setValueAtTime(0, t);
      gainNode.gain.linearRampToValueAtTime(g, t + 0.012);
      gainNode.gain.linearRampToValueAtTime(0, t + dur);

      src.connect(bp);
      bp.connect(gainNode);
      gainNode.connect(ctx.destination);

      src.start(t);
      src.stop(t + dur + 0.06);
    });
  }

  container?.addEventListener('mouseenter', () => {
    if (spinTimer) { clearInterval(spinTimer); spinTimer = null; }

    playDJScratch();

    const anim = record?.getAnimations()[0];
    if (!anim) return;

    let rate = 1;
    slowTimer = setInterval(() => {
      rate = Math.max(0, rate - 0.06);
      anim.updatePlaybackRate(rate);
      if (rate <= 0 && slowTimer) { clearInterval(slowTimer); slowTimer = null; }
    }, 16);
  });

  container?.addEventListener('mouseleave', () => {
    if (slowTimer) { clearInterval(slowTimer); slowTimer = null; }

    const anim = record?.getAnimations()[0];
    if (!anim) return;

    let rate = anim.playbackRate;
    spinTimer = setInterval(() => {
      rate = Math.min(1, rate + 0.025);
      anim.updatePlaybackRate(rate);
      if (rate >= 1 && spinTimer) { clearInterval(spinTimer); spinTimer = null; }
    }, 16);
  });
</script>
