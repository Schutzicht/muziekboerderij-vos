---
import { Menu, X } from 'lucide-astro';
---

<div id="header-wrap" class="fixed top-0 left-0 w-full z-50 flex justify-center pt-5 transition-all duration-500">
  <header id="main-header" class="w-full max-w-5xl mx-4 rounded-2xl px-6 py-3 flex justify-between items-center bg-primary-green/40 backdrop-blur-xl border border-white/10 shadow-xl transition-all duration-500">

    <!-- Logo -->
    <a href="/" class="flex items-baseline gap-2 group">
      <span class="text-sm font-fredoka font-bold text-white/60 group-hover:text-white transition-colors uppercase tracking-widest">Muziekboerderij</span>
      <span class="text-xl font-fredoka font-bold text-accent-tan uppercase">VOS</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      <ul class="flex gap-6 list-none">
        <li><a href="#over-ons" class="text-xs font-medium text-white/70 hover:text-accent-tan transition-colors uppercase tracking-widest">Over Ons</a></li>
        <li><a href="#loodsen" class="text-xs font-medium text-white/70 hover:text-accent-tan transition-colors uppercase tracking-widest">Loodsen</a></li>
        <li><a href="#camping" class="text-xs font-medium text-white/70 hover:text-accent-tan transition-colors uppercase tracking-widest">Camping</a></li>
        <li><a href="#vodatenten" class="text-xs font-medium text-white/70 hover:text-accent-tan transition-colors uppercase tracking-widest">Vodatenten</a></li>
        <li><a href="#tarieven" class="text-xs font-medium text-white/70 hover:text-accent-tan transition-colors uppercase tracking-widest">Tarieven</a></li>
        <li><a href="#contact" class="text-xs font-medium text-white/70 hover:text-accent-tan transition-colors uppercase tracking-widest">Contact</a></li>
      </ul>
      <a href="#contact" class="bg-accent-tan text-primary-green px-5 py-2 rounded-full font-semibold text-xs uppercase tracking-wider hover:bg-white transition-all hover:scale-105">
        Boeken
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden text-white hover:text-accent-tan transition-colors outline-none">
      <Menu size={24} class="menu-open" />
      <X size={24} class="menu-close hidden" />
    </button>
  </header>

  <!-- Mobile Dropdown -->
  <div id="mobile-dropdown" class="absolute top-full mt-2 left-4 right-4 max-w-5xl mx-auto bg-primary-green/90 backdrop-blur-xl rounded-2xl border border-white/10 shadow-2xl hidden overflow-hidden">
    <ul class="flex flex-col items-center py-8 gap-6 list-none">
      <li><a href="#over-ons" class="text-sm font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Over Ons</a></li>
      <li><a href="#loodsen" class="text-sm font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Loodsen</a></li>
      <li><a href="#camping" class="text-sm font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Camping</a></li>
      <li><a href="#vodatenten" class="text-sm font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Vodatenten</a></li>
      <li><a href="#tarieven" class="text-sm font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Tarieven</a></li>
      <li><a href="#contact" class="text-sm font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Contact</a></li>
      <li>
        <a href="#contact" class="bg-accent-tan text-primary-green px-8 py-2.5 rounded-full font-semibold text-sm uppercase tracking-wider mobile-link">
          Boeken
        </a>
      </li>
    </ul>
  </div>
</div>

<script>
  const header = document.getElementById('main-header');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileDropdown = document.getElementById('mobile-dropdown');
  const openIcon = mobileMenuBtn?.querySelector('.menu-open');
  const closeIcon = mobileMenuBtn?.querySelector('.menu-close');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      header?.classList.add('bg-primary-green/80', 'border-white/20', 'shadow-2xl');
      header?.classList.remove('bg-primary-green/40', 'border-white/10');
    } else {
      header?.classList.remove('bg-primary-green/80', 'border-white/20', 'shadow-2xl');
      header?.classList.add('bg-primary-green/40', 'border-white/10');
    }
  });

  mobileMenuBtn?.addEventListener('click', () => {
    mobileDropdown?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileDropdown?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
