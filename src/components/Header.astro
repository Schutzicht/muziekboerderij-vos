---
import { Menu, X } from 'lucide-astro';
---

<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300 py-6">
  <nav class="container mx-auto px-6 flex justify-between items-center">
    <!-- Logo -->
    <a href="/" class="flex flex-col leading-tight group">
      <span class="text-xl font-fredoka font-bold text-white group-hover:text-accent-tan transition-colors uppercase tracking-widest">Muziekboerderij</span>
      <span class="text-3xl font-fredoka font-bold text-accent-tan uppercase">VOS</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-10">
      <ul class="flex gap-8 list-none">
        <li><a href="#over-ons" class="text-sm font-medium text-white/90 hover:text-accent-tan transition-colors uppercase tracking-widest">Over Ons</a></li>
        <li><a href="#loodsen" class="text-sm font-medium text-white/90 hover:text-accent-tan transition-colors uppercase tracking-widest">Loodsen</a></li>
        <li><a href="#camping" class="text-sm font-medium text-white/90 hover:text-accent-tan transition-colors uppercase tracking-widest">Camping</a></li>
        <li><a href="#vodatenten" class="text-sm font-medium text-white/90 hover:text-accent-tan transition-colors uppercase tracking-widest">Vodatenten</a></li>
        <li><a href="#tarieven" class="text-sm font-medium text-white/90 hover:text-accent-tan transition-colors uppercase tracking-widest">Tarieven</a></li>
        <li><a href="#contact" class="text-sm font-medium text-white/90 hover:text-accent-tan transition-colors uppercase tracking-widest">Contact</a></li>
      </ul>
      <a href="#contact" class="bg-accent-tan text-primary-green px-8 py-3 rounded-full font-bold text-sm uppercase tracking-widest hover:bg-white transition-all transform hover:scale-105 hover:shadow-xl">
        BOEKEN
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden text-white hover:text-accent-tan transition-colors outline-none">
      <Menu size={32} class="menu-open" />
      <X size={32} class="menu-close hidden" />
    </button>
  </nav>

  <!-- Mobile Dropdown (simplified for now) -->
  <div id="mobile-dropdown" class="absolute top-full left-0 w-full bg-primary-green/95 backdrop-blur-lg hidden border-b border-white/10">
    <ul class="flex flex-col items-center py-10 gap-8 list-none">
      <li><a href="#over-ons" class="text-lg font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Over Ons</a></li>
      <li><a href="#loodsen" class="text-lg font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Loodsen</a></li>
      <li><a href="#camping" class="text-lg font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Camping</a></li>
      <li><a href="#vodatenten" class="text-lg font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Vodatenten</a></li>
      <li><a href="#tarieven" class="text-lg font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Tarieven</a></li>
      <li><a href="#contact" class="text-lg font-medium text-white hover:text-accent-tan transition-colors uppercase tracking-widest mobile-link">Contact</a></li>
      <li>
        <a href="#contact" class="bg-accent-tan text-primary-green px-10 py-4 rounded-full font-bold text-lg uppercase tracking-widest mobile-link">
          BOEKEN
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileDropdown = document.getElementById('mobile-dropdown');
  const openIcon = mobileMenuBtn?.querySelector('.menu-open');
  const closeIcon = mobileMenuBtn?.querySelector('.menu-close');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  // Sticky header logic
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-primary-green/90', 'backdrop-blur-md', 'shadow-2xl', 'py-4');
      header?.classList.remove('py-6');
    } else {
      header?.classList.remove('bg-primary-green/90', 'backdrop-blur-md', 'shadow-2xl', 'py-4');
      header?.classList.add('py-6');
    }
  });

  // Mobile menu logic
  mobileMenuBtn?.addEventListener('click', () => {
    mobileDropdown?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
  
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileDropdown?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
