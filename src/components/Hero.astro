---
---

<section id="hero" class="relative h-screen w-full flex items-center justify-center overflow-hidden">
  <!-- Background Image with Parallax -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/hero.png" 
      alt="Muziekboerderij Vos" 
      class="w-full h-full object-cover transform scale-110"
      id="hero-bg"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-primary-green/80 via-primary-green/40 to-off-white z-10"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto px-6 relative z-30 text-center">
    <div class="space-y-6 max-w-4xl mx-auto">
      <h1 class="text-white text-display leading-tight mb-4 animate-in fade-in slide-in-from-bottom-10 duration-1000">
        Jouw Eigen Geluid <br/>
        <span class="text-accent-tan">In De Zeeuwse Polder.</span>
      </h1>
      
      <p class="text-white/90 text-lg md:text-2xl font-medium max-w-2xl mx-auto leading-relaxed animate-in fade-in slide-in-from-bottom-12 duration-1000 delay-200">
        Muziek maken en buiten leven. 12 inspirerende loodsen, 30 vaste bands en onbeperkte ruimte voor jouw creativiteit.
      </p>

      <div class="flex flex-col md:flex-row gap-4 md:gap-6 justify-center pt-8 md:pt-10 animate-in fade-in slide-in-from-bottom-14 duration-1000 delay-400">
        <a href="#loodsen" class="w-full md:w-auto flex justify-center items-center group bg-accent-tan text-primary-green px-8 md:px-10 py-5 rounded-full font-bold text-lg uppercase tracking-widest hover:bg-white transition-all transform hover:scale-105 shadow-2xl">
          Ontdek de Loodsen
          <span class="inline-block transition-transform group-hover:translate-x-2 ml-2">→</span>
        </a>
        <a href="#camping" class="w-full md:w-auto flex justify-center items-center group border-2 border-white/40 text-white px-8 md:px-10 py-5 rounded-full font-bold text-lg uppercase tracking-widest hover:bg-white hover:text-primary-green hover:border-white transition-all transform hover:scale-105 shadow-xl backdrop-blur-sm">
          Bekijk de camping
        </a>
      </div>
    </div>
  </div>


</section>

<style>
  .text-display {
    font-size: clamp(2rem, 6vw, 4rem);
  }
</style>

<script>
  // Simple parallax effect for hero background
  window.addEventListener('scroll', () => {
    const scroll = window.scrollY;
    const heroBg = document.getElementById('hero-bg');
    if (heroBg) {
      heroBg.style.transform = `scale(1.1) translateY(${scroll * 0.2}px)`;
    }
  });
</script>
