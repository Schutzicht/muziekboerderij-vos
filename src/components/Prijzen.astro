---
---

<section id="tarieven" class="py-24 md:py-32 bg-off-white">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto text-center mb-20 animate-on-scroll">
      <p class="text-accent-tan uppercase tracking-widest text-sm font-bold mb-4 font-montserrat">Transparante prijzen</p>
      <h2 class="text-4xl md:text-7xl mb-6 text-primary-green">Tarieven</h2>
      <p class="text-zinc-500 text-xl font-light font-montserrat">
        Eerlijke prijzen voor elke muzikant. Geen verborgen kosten, gewoon spelen.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto items-center">

      <!-- Loods -->
      <div class="bg-white border border-zinc-100 p-10 rounded-3xl shadow-sm hover:shadow-xl transition-all animate-on-scroll">
        <div class="mb-8">
          <p class="text-accent-tan uppercase tracking-widest text-xs font-bold mb-4 font-montserrat">Muziekloods</p>
          <div class="flex items-end gap-1 mb-2">
            <span class="text-6xl font-fredoka font-bold text-primary-green">€35</span>
            <span class="text-zinc-400 mb-3 font-montserrat text-sm">/uur</span>
          </div>
          <p class="text-zinc-400 text-sm font-montserrat font-light">Inclusief backline, verlichting en klimaatregeling.</p>
        </div>
        <ul class="space-y-3 mb-10 font-montserrat">
          <li class="flex items-center gap-3 text-sm text-zinc-600"><span class="text-accent-tan font-bold">✓</span> Tot 10 personen</li>
          <li class="flex items-center gap-3 text-sm text-zinc-600"><span class="text-accent-tan font-bold">✓</span> PA-systeem aanwezig</li>
          <li class="flex items-center gap-3 text-sm text-zinc-600"><span class="text-accent-tan font-bold">✓</span> Drumkit beschikbaar</li>
          <li class="flex items-center gap-3 text-sm text-zinc-600"><span class="text-accent-tan font-bold">✓</span> Wifi & stroom</li>
        </ul>
        <a href="#contact" class="block text-center border-2 border-primary-green text-primary-green py-4 rounded-2xl font-bold uppercase tracking-widest text-sm hover:bg-primary-green hover:text-white transition-all font-montserrat">
          Reserveren
        </a>
      </div>

      <!-- Camping - featured -->
      <div class="bg-primary-green p-10 rounded-3xl shadow-2xl relative animate-on-scroll delay-100 scale-105">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-accent-tan text-primary-green text-xs font-bold uppercase tracking-widest px-6 py-2 rounded-full font-montserrat whitespace-nowrap">
          Populairste
        </div>
        <div class="mb-8">
          <p class="text-accent-tan uppercase tracking-widest text-xs font-bold mb-4 font-montserrat">Camping</p>
          <div class="flex items-end gap-1 mb-2">
            <span class="text-6xl font-fredoka font-bold text-white">€15</span>
            <span class="text-white/50 mb-3 font-montserrat text-sm">/p.p. per nacht</span>
          </div>
          <p class="text-white/40 text-sm font-montserrat font-light">Midden in de muziek, buiten slapen.</p>
        </div>
        <ul class="space-y-3 mb-10 font-montserrat">
          <li class="flex items-center gap-3 text-sm text-white/80"><span class="text-accent-tan font-bold">✓</span> Vaste kampeerplaats</li>
          <li class="flex items-center gap-3 text-sm text-white/80"><span class="text-accent-tan font-bold">✓</span> Sanitair & douches</li>
          <li class="flex items-center gap-3 text-sm text-white/80"><span class="text-accent-tan font-bold">✓</span> Toegang tot loods</li>
          <li class="flex items-center gap-3 text-sm text-white/80"><span class="text-accent-tan font-bold">✓</span> Live avondprogramma</li>
        </ul>
        <a href="#contact" class="block text-center bg-accent-tan text-primary-green py-4 rounded-2xl font-bold uppercase tracking-widest text-sm hover:bg-white transition-all font-montserrat">
          Boeken
        </a>
      </div>

      <!-- Vodatent -->
      <div class="bg-white border border-zinc-100 p-10 rounded-3xl shadow-sm hover:shadow-xl transition-all animate-on-scroll delay-200">
        <div class="mb-8">
          <p class="text-accent-tan uppercase tracking-widest text-xs font-bold mb-4 font-montserrat">Vodatent</p>
          <div class="flex items-end gap-1 mb-2">
            <span class="text-6xl font-fredoka font-bold text-primary-green">€95</span>
            <span class="text-zinc-400 mb-3 font-montserrat text-sm">/nacht</span>
          </div>
          <p class="text-zinc-400 text-sm font-montserrat font-light">Luxe glamping voor 2–6 personen in de polder.</p>
        </div>
        <ul class="space-y-3 mb-10 font-montserrat">
          <li class="flex items-center gap-3 text-sm text-zinc-600"><span class="text-accent-tan font-bold">✓</span> Volledig ingericht</li>
          <li class="flex items-center gap-3 text-sm text-zinc-600"><span class="text-accent-tan font-bold">✓</span> Privé buitenruimte</li>
          <li class="flex items-center gap-3 text-sm text-zinc-600"><span class="text-accent-tan font-bold">✓</span> Bedden & beddengoed</li>
          <li class="flex items-center gap-3 text-sm text-zinc-600"><span class="text-accent-tan font-bold">✓</span> Ontbijt optioneel</li>
        </ul>
        <a href="#contact" class="block text-center border-2 border-primary-green text-primary-green py-4 rounded-2xl font-bold uppercase tracking-widest text-sm hover:bg-primary-green hover:text-white transition-all font-montserrat">
          Boeken
        </a>
      </div>

    </div>
  </div>
</section>
